APP_NAME="FastAPI Secure Backend"
DEBUG=true

# Banco de Dados (usando driver asyncpg)
DATABASE_URL=postgresql+asyncpg://appuser:apppass@postgres:5432/appdb

# Segurança JWT (gere com secrets.token_hex(64))
JWT_ACCESS_SECRET=substituir_por_uma_string_hex_aleatoria_de_64_caracteres
JWT_REFRESH_SECRET=substituir_por_outra_string_hex_aleatoria_diferente

# Criptografia AES-256-GCM (gere com secrets.token_hex(32))
TASK_ENCRYPTION_KEY_HEX=7a4b9c1d2e3f4a5b6c7d8e9f0a1b2c3d4e5f6a7b8c9d0e1f2a3b4c5d6e7f8a9b

# Configurações de Token
JWT_ACCESS_EXPIRE_MINUTES=15
JWT_REFRESH_EXPIRE_DAYS=7